            if (confirm("Are you sure you want to delete this movie?")) {
                window.CineBookState.movies =3D
window.CineBookState.movies.filter(m =3D> m.id !=3D=3D movieId);
                saveData();
                renderAdminMovies();
                showToast("Movie deleted successfully");
