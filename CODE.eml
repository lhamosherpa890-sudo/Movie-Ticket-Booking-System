d>
                    <td style=3D"color:var(--success);font-weight:600">NPR
${b.total}</td>
                    <td><span style=3D"color:var(--success); font-size:12px=
;
font-weight:700;">=E2=9C=93 ${b.status.toUpperCase()}</span></td>
                </tr>`).join("");
        }

