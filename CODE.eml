        function openSeatModal() {
            const booking =3D window.CineBookState.currentBooking;
            const movie =3D window.CineBookState.movies.find(m =3D> m.id =
=3D=3D=3D
booking.movieId);
            if (!movie) return;

            document.getElementById("seat-modal-title").innerText =3D
movie.title;
            document.getElementById("seat-modal-sub").innerText =3D
`${getDateLabel(booking.dateOffset)} =E2=80=A2 ${booking.showtime} | Main S=
creen`;
            document.getElementById("sum-price").innerText =3D `NPR
${movie.price}`;

            const gridContainer =3D document.getElementById("seat-grid");
            gridContainer.style.gridTemplateColumns =3D
`repeat(${movie.cols}, minmax(30px, 1fr))`;
            gridContainer.innerHTML =3D "";

            const bookedList =3D movie.bookedSeats[booking.showtime] || [];

            for (let r =3D 0; r < movie.rows; r++) {
                const rowLetter =3D String.fromCharCode(65 + r);
                for (let c =3D 1; c <=3D movie.cols; c++) {
                    const seatId =3D `${rowLetter}-${c}`;
                    const seatDiv =3D document.createElement("div");
                    seatDiv.className =3D `seat ${bookedList.includes(seatI=
d)
? 'booked' : 'available'}`;
                    seatDiv.innerText =3D seatId;

                    if (!bookedList.includes(seatId)) {
                        seatDiv.onclick =3D () =3D>
toggleSeatSelection(seatDiv, seatId, movie.price);
                    }
                    gridContainer.appendChild(seatDiv);
                }
            }
            updateBookingSummary(movie.price);
            openModal("modal-seats");
        }

        function toggleSeatSelection(element, seatId, price) {
            const selected =3D
window.CineBookState.currentBooking.selectedSeats;
            const index =3D selected.indexOf(seatId);
            if (index > -1) {
                selected.splice(index, 1);
                element.className =3D "seat available";
            } else {
                selected.push(seatId);
                element.className =3D "seat selected";
            }
            updateBookingSummary(price);
        }

        function updateBookingSummary(price) {
            const selected =3D
window.CineBookState.currentBooking.selectedSeats;
            const summaryBlock =3D document.getElementById("booking-summary=
");
            const proceedBtn =3D document.getElementById("btn-proceed");

            if (selected.length > 0) {
                summaryBlock.style.display =3D "block";
                document.getElementById("sum-seats").innerText =3D
selected.join(", ");
                document.getElementById("sum-total").innerText =3D `NPR
${selected.length * price}`;
                proceedBtn.disabled =3D false;
                proceedBtn.innerText =3D `Proceed to Payment
(${selected.length} Selected)`;
            } else {
                summaryBlock.style.display =3D "none";
                proceedBtn.disabled =3D true;
                proceedBtn.innerText =3D "Select seats to continue";
            }
        }

        function proceedToPayment() {
            closeModal("modal-seats");
            const booking =3D window.CineBookState.currentBooking;
            const movie =3D window.CineBookState.movies.find(m =3D> m.id =
=3D=3D=3D
booking.movieId);
            if (!movie) return;

            document.getElementById("pay-modal-sub").innerText =3D
`${movie.title} =E2=80=A2 ${getDateLabel(booking.dateOffset)} =E2=80=A2
${booking.showtime}`;
            document.getElementById("pay-sum-movie").innerText =3D
movie.title;
            document.getElementById("pay-sum-time").innerText =3D
booking.showtime;
            document.getElementById("pay-sum-seats").innerText =3D
booking.selectedSeats.join(", ");
            document.getElementById("pay-sum-total").innerText =3D `NPR
${booking.selectedSeats.length * movie.price}`;

            document.getElementById("pay-name").value =3D "";
            document.getElementById("pay-email").value =3D "";
            document.getElementById("pay-phone").value =3D "";
            openModal("modal-payment");
        }

        function togglePaymentFields() {
            const method =3D document.getElementById("pay-method").value;
            document.getElementById("card-fields").style.display =3D method
=3D=3D=3D "card" ? "block" : "none";
            document.getElementById("wallet-fields").style.display =3D meth=
od
=3D=3D=3D "card" ? "none" : "block";
            if (method !=3D=3D "card") {
                document.getElementById("wallet-label").innerText =3D
`${method.toUpperCase()} ID / Mobile Number`;
            }
        }

        function formatCard(el) { el.value =3D el.value.replace(/\D/g,
"").replace(/(.{4})/g, '$1 ').trim(); }
        function formatExpiry(el) { el.value =3D el.value.replace(/\D/g,
"").replace(/(.{2})/, '$1 / ').substring(0, 7); }

        function confirmPayment() {
            const name =3D document.getElementById("pay-name").value.trim()=
;
            const email =3D document.getElementById("pay-email").value.trim=
();
            const phone =3D document.getElementById("pay-phone").value.trim=
();

            if (!name || !email || !phone) {
                showToast("Please fill all information fields", "error");
                return;
            }

            const booking =3D window.CineBookState.currentBooking;
            const movie =3D window.CineBookState.movies.find(m =3D> m.id =
=3D=3D=3D
booking.movieId);
            const totalAmount =3D booking.selectedSeats.length * movie.pric=
e;
            const bookingId =3D "CB-" + Math.floor(100000 + Math.random() *
900000);

            const newBooking =3D {
                id: bookingId,
                customerName: name,
                customerEmail: email,
                customerPhone: phone,
                movieTitle: movie.title,
                movieId: movie.id,
                showtime: booking.showtime,
                seats: [...booking.selectedSeats],
                total: totalAmount,
                status: "Confirmed"
            };

            window.CineBookState.bookings.push(newBooking);
            if (!movie.bookedSeats[booking.showtime])
movie.bookedSeats[booking.showtime] =3D [];

movie.bookedSeats[booking.showtime].push(...booking.selectedSeats);

            saveData();
            closeModal("modal-payment");

            document.getElementById("ticket-card").innerHTML =3D `
                <div style=3D"background: rgba(255,255,255,0.05); border: 2=
px
dashed rgba(99,102,241,0.4); border-radius: 8px; padding: 20px; margin-top:
20px; text-align: left; font-family: monospace; font-size: 13px;">
                    <div style=3D"text-align: center; font-weight: bold;
font-size: 14px; margin-bottom: 14px; color: var(--primary);">=F0=9F=8E=AB =
CINEBOOK
DIGITAL TICKET</div>
                    <div style=3D"display:flex;
justify-content:space-between; margin-bottom:6px;"><span>TICKET
ID:</span><span style=3D"color:#fff;font-weight:700">${bookingId}</span></d=
iv>
                    <div style=3D"display:flex;
justify-content:space-between; margin-bottom:6px;"><span>MOVIE:</span><span
style=3D"color:#fff;font-weight:700">${movie.title}</span></div>
                    <div style=3D"display:flex;
justify-content:space-between; margin-bottom:6px;"><span>DATE:</span><span
style=3D"color:#fff;font-weight:700">${getDateLabel(booking.dateOffset)}</s=
pan></div>
                    <div style=3D"display:flex;
justify-content:space-between;
margin-bottom:6px;"><span>SHOWTIME:</span><span
style=3D"color:#fff;font-weight:700">${booking.showtime}</span></div>
                    <div style=3D"display:flex;
justify-content:space-between; margin-bottom:6px;"><span>SEATS:</span><span
style=3D"color:#fff;font-weight:700">${booking.selectedSeats.join(",
