        function getDateString(daysOffset =3D 0) {
            const date =3D new Date();
            date.setDate(date.getDate() + daysOffset);
            return date.toLocaleDateString('en-US', { month: 'short', day:
'numeric' });
        }

        function getDateLabel(daysOffset =3D 0) {
            if (daysOffset =3D=3D=3D 0) return "Today";
            if (daysOffset =3D=3D=3D 1) return "Tomorrow";
            return getDateString(daysOffset);
        }

