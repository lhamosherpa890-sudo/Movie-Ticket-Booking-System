                    <td>NPR ${movie.price}</td>
                    <td><span style=3D"background: ${movie.dateOffset =3D=
=3D=3D 0 ?
'rgba(16,185,129,0.2)' : 'rgba(99,102,241,0.2)'}; padding: 4px 8px;
border-radius: 4px; font-size: 12px; font-weight:
600;">${getDateLabel(movie.dateOffset)}</span></td>
                    <td>${movie.rows} =C3=97 ${movie.cols}</td>
                    <td style=3D"font-size: 12px;">${movie.showtimes.join("=
,
")}</td>
                    <td>
                        <button class=3D"delete-btn" onclick=3D"deleteMovie=
('${
movie.id}')">=F0=9F=97=91=EF=B8=8F Delete</button>
                    </td>
                </tr>`).join("");
        }

        function renderAdminBookings() {
            const container =3D
document.getElementById("admin-bookings-list");
            if (!container) return;

            if (window.CineBookState.bookings.length =3D=3D=3D 0) {
                container.innerHTML =3D `<tr><td colspan=3D"7"
style=3D"text-align:center;color:var(--muted);padding:32px">No bookings
yet</td></tr>`;
                return;
            }

            container.innerHTML =3D window.CineBookState.bookings.map(b =3D=
> `
                <tr>
                    <td><span style=3D"font-family:monospace;
color:var(--accent); font-weight: 700">${b.id}</span></td>
                    <td>${b.customerName}<br><small
