=3D=3D=3D=3D=3D
        function adminLogin() {
            const user =3D document.getElementById("admin-user").value;
            const pass =3D document.getElementById("admin-pass").value;
            if (user =3D=3D=3D "admin" && pass =3D=3D=3D "admin123") {
                window.CineBookState.isAdmin =3D true;
                showToast("Welcome back, administrator!");
                showPage("admin");
            } else {
                showToast("Invalid credentials", "error");
            }
        }

        function adminLogout() {
            window.CineBookState.isAdmin =3D false;
            showToast("Logged out successfully");
            showPage("home");
        }

        function switchAdminTab(tabName) {
            document.querySelectorAll(".admin-nav-item").forEach(item =3D>
item.classList.remove("active"));
            document.querySelectorAll(".admin-section").forEach(sec =3D>
sec.classList.remove("active"));

document.getElementById(`tab-${tabName}`).classList.add("active");

document.getElementById(`admin-${tabName}`).classList.add("active");
        }

        // MODIFIED: addMovie - includes dateOffset handling
        function addMovie() {
            const title =3D document.getElementById("m-title").value.trim()=
;
            const genre =3D document.getElementById("m-genre").value.trim()=
;
            const duration =3D
parseInt(document.getElementById("m-duration").value);
            const price =3D
parseInt(document.getElementById("m-price").value);
            const rawTimes =3D document.getElementById("m-showtimes").value=
;
            const rows =3D parseInt(document.getElementById("m-rows").value=
);
            const cols =3D parseInt(document.getElementById("m-cols").value=
);
            const poster =3D document.getElementById("m-poster").value.trim=
();
            const dateOffset =3D
parseInt(document.getElementById("m-date").value);

            if (!title || !genre || !duration || !price || !rawTimes ||
!rows || !cols) {
                showToast("Please provide all required fields", "error");
                return;
            }

            const showtimes =3D rawTimes.split(",").map(t =3D>
t.trim()).filter(t =3D> t.length > 0);
            const bookedSeatsMap =3D {};
            showtimes.forEach(t =3D> { bookedSeatsMap[t] =3D []; });

            const newMovie =3D {
                id: "m-" + Date.now(),
                title,
                genre,
                duration,
                price,
                showtimes,
                rows,
                cols,
                poster: poster || null,
                dateOffset,
                bookedSeats: bookedSeatsMap
            };

            window.CineBookState.movies.push(newMovie);
            saveData();

            // Clear form
            document.getElementById("m-title").value =3D "";
            document.getElementById("m-genre").value =3D "";
            document.getElementById("m-duration").value =3D "";
            document.getElementById("m-price").value =3D "";
            document.getElementById("m-showtimes").value =3D "";
            document.getElementById("m-poster").value =3D "";
            document.getElementById("m-date").value =3D "0";

            showToast("Movie added successfully!");
            renderAdminMovies();
        }

